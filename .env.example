APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:e0TLfDLxIDrMVqMgUzeenDSpHjGx2kBQxRHRFUbS614=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql_container
DB_PORT=3306
DB_DATABASE=xampinho_db
DB_USERNAME=xamps
DB_PASSWORD=xamps

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"
# Local: se preenchido, redireciona TODOS os e-mails para este endereço. Deixe vazio em produção.
MAIL_TO_OVERRIDE=

# Resend (envio de e-mail transacional) — gere a chave em https://resend.com/api-keys
RESEND_API_KEY=

# AWS S3 — preencha AWS_ACCESS_KEY_ID e AWS_SECRET_ACCESS_KEY no seu .env (nunca commite segredos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=jftec
AWS_URL=https://jftec.s3.sa-east-1.amazonaws.com/
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# OpenAI (AI Command Bar)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TIMEOUT=30

# Deploy webhook (public/deploy.php) — git pull automático no push do GitHub
DEPLOY_WEBHOOK_SECRET=
DEPLOY_BRANCH=main
DEPLOY_GIT_BIN=git
